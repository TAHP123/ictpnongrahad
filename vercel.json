{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "ctf_challenge.html", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/robots.txt", "dest": "robots.txt" },
    { "src": "/", "dest": "ctf_challenge.html" }
  ]
}
